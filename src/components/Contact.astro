---
import Section from "./Section.astro";

interface Props {
  email: string;
}

const { email } = Astro.props;
---

<Section text="Contact" href="contact">
  <div class="max-w-xl mx-auto text-center">
    <p class="text-neutral text-base mb-8">
      Have a project in mind or just want to say hello? Drop me a message and I'll get back to you.
    </p>

    <form
      action="https://formspree.io/f/myknzvyy"
      method="POST"
      class="space-y-5 text-left"
      id="contact-form"
    >
      <!-- Replace the Formspree form ID above with your own from https://formspree.io -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="name" class="block text-sm font-medium text-neutral mb-1.5">Name</label>
          <input
            type="text"
            name="name"
            id="name"
            required
            class="w-full rounded-lg border border-neutral/30 bg-transparent px-4 py-3 text-sm text-white placeholder-neutral/50 outline-none transition-colors focus:border-primary"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-neutral mb-1.5">Email</label>
          <input
            type="email"
            name="email"
            id="email"
            required
            class="w-full rounded-lg border border-neutral/30 bg-transparent px-4 py-3 text-sm text-white placeholder-neutral/50 outline-none transition-colors focus:border-primary"
            placeholder="you@example.com"
          />
        </div>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-neutral mb-1.5">Message</label>
        <textarea
          name="message"
          id="message"
          required
          rows="5"
          class="w-full resize-none rounded-lg border border-neutral/30 bg-transparent px-4 py-3 text-sm text-white placeholder-neutral/50 outline-none transition-colors focus:border-primary"
          placeholder="Tell me about your project..."
        ></textarea>
      </div>

      <!-- Honeypot for spam -->
      <input type="text" name="_gotcha" class="hidden" />

      <div class="text-center">
        <button
          type="submit"
          class="inline-flex items-center gap-2 rounded-full bg-primary px-8 py-3 text-sm font-medium text-[#fff] transition-opacity hover:opacity-90"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>
          Send Message
        </button>
      </div>
    </form>

    <p id="form-status" class="mt-4 text-sm hidden"></p>
  </div>
</Section>

<script is:inline>
  function initContactForm() {
    var form = document.getElementById("contact-form");
    var status = document.getElementById("form-status");
    if (!form) return;

    form.addEventListener("submit", function(e) {
      e.preventDefault();
      var btn = form.querySelector("button[type=submit]");
      btn.disabled = true;
      btn.textContent = "Sending...";

      fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      }).then(function(res) {
        if (res.ok) {
          status.textContent = "Message sent! I'll get back to you soon.";
          status.className = "mt-4 text-sm text-green-400";
          status.classList.remove("hidden");
          form.reset();
        } else {
          throw new Error("Failed");
        }
      }).catch(function() {
        status.textContent = "Something went wrong. Try emailing me directly.";
        status.className = "mt-4 text-sm text-red-400";
        status.classList.remove("hidden");
      }).finally(function() {
        btn.disabled = false;
        btn.textContent = "Send Message";
      });
    });
  }
  initContactForm();
  document.addEventListener("astro:page-load", initContactForm);
</script>
