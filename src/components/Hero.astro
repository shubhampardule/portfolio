---
import type { HeroProps } from "@types";
import ParticleCanvas from "./ParticleCanvas.astro";
type Props = HeroProps;

const { name, specialty, summary, email } = Astro.props;
---

<section class="scroll-reveal relative py-24 md:py-32" id="#hero">
  <ParticleCanvas />
  <div class="relative z-10">
  <h1
    class="mb-1.5 font-serif text-5xl font-bold tracking-tightest text-white sm:text-7xl md:mb-0 md:text-9xl"
  >
    {name}
  </h1>
  <p
    class="mb-9 font-serif text-2xl leading-tight font-bold tracking-tighter text-primary sm:text-4xl sm:leading-[46px] md:text-6xl"
  >
    <span id="typewriter-text">{specialty}</span><span id="typewriter-cursor" class="inline-block w-[3px] h-[1em] bg-primary align-middle ml-1 animate-blink"></span>
  </p>
  <p class="mb-16 text-base font-normal text-neutral md:text-lg">
    {summary}
  </p>

  <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
  <a
    class="inline-block rounded-full bg-primary px-8 py-5 text-sm leading-5 font-medium text-[#fff] text-center"
    href="#contact">Get in Touch</a
  >
  <a
    class="inline-flex items-center justify-center gap-2 rounded-full border border-neutral/30 px-8 py-5 text-sm leading-5 font-medium text-white hover:border-primary hover:text-primary transition-colors"
    href="/game" data-astro-reload><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/></svg> Asteroid Dodge</a
  >
  </div>
  </div>
</section>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .animate-blink {
    animation: blink 0.7s step-end infinite;
  }
</style>

<script is:inline>
  var _twTimer = 0;
  function initTypewriter() {
    clearTimeout(_twTimer);
    var el = document.getElementById("typewriter-text");
    if (!el) return;

    var roles = [
      "Full Stack Developer",
      "Problem Solver",
      "UI Engineer",
      "Code Enthusiast",
      "Tech Explorer"
    ];

    var state = { ri: 0, ci: roles[0].length, deleting: false };

    function tick() {
      // Re-get element in case DOM changed (view transitions)
      var target = document.getElementById("typewriter-text");
      if (!target) return;

      var word = roles[state.ri];

      if (state.deleting) {
        state.ci--;
        target.textContent = word.substring(0, state.ci);
        if (state.ci <= 0) {
          state.deleting = false;
          state.ri = (state.ri + 1) % roles.length;
          _twTimer = setTimeout(tick, 300);
        } else {
          _twTimer = setTimeout(tick, 40);
        }
      } else {
        state.ci++;
        target.textContent = word.substring(0, state.ci);
        if (state.ci >= word.length) {
          state.deleting = true;
          _twTimer = setTimeout(tick, 2000);
        } else {
          _twTimer = setTimeout(tick, 80);
        }
      }
    }

    _twTimer = setTimeout(tick, 2000);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTypewriter);
  } else {
    initTypewriter();
  }

  document.addEventListener("astro:page-load", function() {
    initTypewriter();
  });
</script>
