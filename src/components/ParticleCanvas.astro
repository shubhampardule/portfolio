---
/**
 * Interactive particle constellation background.
 * Particles float with slight drift, connect with lines when close,
 * and repel away from the mouse cursor with physics.
 */
---

<canvas id="particle-canvas" class="pointer-events-none absolute inset-0 z-0 h-full w-full"></canvas>

<script>
  const canvas = document.getElementById("particle-canvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  // --- Config ---
  const PARTICLE_COUNT_DESKTOP = 80;
  const PARTICLE_COUNT_MOBILE = 40;
  const CONNECTION_DISTANCE = 140;
  const MOUSE_RADIUS = 160;
  const MOUSE_FORCE = 0.08;
  const FRICTION = 0.96;
  const BASE_SPEED = 0.3;
  const PARTICLE_MIN_SIZE = 1;
  const PARTICLE_MAX_SIZE = 2.5;

  // --- State ---
  let width = 0;
  let height = 0;
  let mouseX = -9999;
  let mouseY = -9999;
  let animationId: number;
  let particles: Particle[] = [];

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
    baseVx: number;
    baseVy: number;
  }

  function getParticleCount() {
    return window.innerWidth < 768 ? PARTICLE_COUNT_MOBILE : PARTICLE_COUNT_DESKTOP;
  }

  function getThemeColors() {
    const style = getComputedStyle(document.documentElement);
    const primary = style.getPropertyValue("--theme-primary").trim() || "#2563eb";
    const neutral = style.getPropertyValue("--theme-neutral").trim() || "#94a3b8";
    return { primary, neutral };
  }

  function createParticle(): Particle {
    const angle = Math.random() * Math.PI * 2;
    const speed = BASE_SPEED * (0.5 + Math.random() * 0.5);
    return {
      x: Math.random() * width,
      y: Math.random() * height,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      baseVx: Math.cos(angle) * speed,
      baseVy: Math.sin(angle) * speed,
      size: PARTICLE_MIN_SIZE + Math.random() * (PARTICLE_MAX_SIZE - PARTICLE_MIN_SIZE),
    };
  }

  function resize() {
    const rect = canvas.parentElement!.getBoundingClientRect();
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    width = rect.width;
    height = rect.height;
    canvas.width = width * dpr;
    canvas.height = height * dpr;
    canvas.style.width = `${width}px`;
    canvas.style.height = `${height}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    // Re-initialize particles on resize
    const count = getParticleCount();
    if (particles.length !== count) {
      particles = Array.from({ length: count }, createParticle);
    }
  }

  function update() {
    // Get trail dot positions for interaction
    const trailDots = (window as any).__trailDots as { x: number; y: number; size: number }[] | undefined;
    const heroRect = canvas.parentElement!.getBoundingClientRect();

    for (const p of particles) {
      // Mouse repulsion
      const dx = p.x - mouseX;
      const dy = p.y - mouseY;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < MOUSE_RADIUS && dist > 0) {
        const force = (1 - dist / MOUSE_RADIUS) * MOUSE_FORCE;
        p.vx += (dx / dist) * force * MOUSE_RADIUS;
        p.vy += (dy / dist) * force * MOUSE_RADIUS;
      }

      // Trail dot repulsion â€” trailing dots also push particles
      if (trailDots) {
        for (let i = 0; i < trailDots.length; i += 3) { // every 3rd dot for perf
          const td = trailDots[i];
          const tdx = p.x - (td.x - heroRect.left);
          const tdy = p.y - (td.y - heroRect.top);
          const tdist = Math.sqrt(tdx * tdx + tdy * tdy);
          if (tdist < 80 && tdist > 0) {
            const tforce = (1 - tdist / 80) * 0.04;
            p.vx += (tdx / tdist) * tforce * 80;
            p.vy += (tdy / tdist) * tforce * 80;
          }
        }
      }

      // Drift back toward base velocity
      p.vx += (p.baseVx - p.vx) * 0.01;
      p.vy += (p.baseVy - p.vy) * 0.01;

      // Friction
      p.vx *= FRICTION;
      p.vy *= FRICTION;

      // Move
      p.x += p.vx;
      p.y += p.vy;

      // Wrap around edges
      if (p.x < -10) p.x = width + 10;
      if (p.x > width + 10) p.x = -10;
      if (p.y < -10) p.y = height + 10;
      if (p.y > height + 10) p.y = -10;
    }
  }

  function draw() {
    const { primary, neutral } = getThemeColors();
    ctx.clearRect(0, 0, width, height);

    // Draw connections
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CONNECTION_DISTANCE) {
          const opacity = (1 - dist / CONNECTION_DISTANCE) * 0.15;
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.strokeStyle = hexToRgba(neutral, opacity);
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      }
    }

    // Draw particles
    for (const p of particles) {
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = hexToRgba(primary, 0.6);
      ctx.fill();
    }
  }

  function hexToRgba(hex: string, alpha: number): string {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `rgba(${r},${g},${b},${alpha})`;
  }

  function loop() {
    update();
    draw();
    animationId = requestAnimationFrame(loop);
  }

  // Pause animation when tab is hidden to save CPU/battery
  document.addEventListener("visibilitychange", () => {
    if (document.hidden) {
      cancelAnimationFrame(animationId);
    } else {
      loop();
    }
  });

  // --- Init ---
  function init() {
    resize();
    particles = Array.from({ length: getParticleCount() }, createParticle);
    loop();
  }

  // Mouse tracking (relative to canvas parent)
  const heroSection = canvas.parentElement!;
  heroSection.addEventListener("mousemove", (e: MouseEvent) => {
    const rect = heroSection.getBoundingClientRect();
    mouseX = e.clientX - rect.left;
    mouseY = e.clientY - rect.top;
  });
  heroSection.addEventListener("mouseleave", () => {
    mouseX = -9999;
    mouseY = -9999;
  });

  // Touch support
  heroSection.addEventListener("touchmove", (e: TouchEvent) => {
    const rect = heroSection.getBoundingClientRect();
    mouseX = e.touches[0].clientX - rect.left;
    mouseY = e.touches[0].clientY - rect.top;
  }, { passive: true });
  heroSection.addEventListener("touchend", () => {
    mouseX = -9999;
    mouseY = -9999;
  });

  window.addEventListener("resize", () => {
    resize();
  });

  // Re-init on theme change to pick up new colors immediately
  const observer = new MutationObserver(() => {
    // Colors update automatically in draw() via getThemeColors()
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });

  // Pause when not visible
  document.addEventListener("visibilitychange", () => {
    if (document.hidden) {
      cancelAnimationFrame(animationId);
    } else {
      loop();
    }
  });

  init();
</script>
