---
import Layout from "@layouts/Layout.astro";
import "../styles/global.css";
---

<Layout>
  <section class="relative flex min-h-[70vh] flex-col items-center justify-center overflow-hidden py-20 text-center">
    <canvas id="space-404" class="pointer-events-none absolute inset-0 z-0 h-full w-full"></canvas>

    <div class="relative z-10">
      <h1 class="text-6xl font-bold leading-none tracking-tighter text-white sm:text-[8rem] md:text-[12rem]">
        4<span class="inline-block animate-spin-slow text-primary">0</span>4
      </h1>
      <p class="mt-2 text-lg text-neutral">Lost in space. This page doesn't exist.</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-full bg-primary px-8 py-3 text-sm font-medium text-white transition-opacity hover:opacity-90"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Go Home
        </a>
        <a
          href="/game"
          data-astro-reload
          class="inline-flex items-center gap-2 rounded-full border border-neutral/30 px-8 py-3 text-sm font-medium text-white transition-colors hover:border-primary hover:text-primary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/></svg>
          Play Game
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-spin-slow {
    animation: spin-slow 8s linear infinite;
  }
</style>

<script>
  const canvas = document.getElementById("space-404") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  let W = 0, H = 0;
  function resize() {
    const rect = canvas.parentElement!.getBoundingClientRect();
    W = canvas.width = rect.width;
    H = canvas.height = rect.height;
  }
  resize();
  window.addEventListener("resize", resize);

  // Stars
  interface Star { x: number; y: number; r: number; a: number; twinkleSpeed: number; }
  const stars: Star[] = [];
  for (let i = 0; i < 120; i++) {
    stars.push({
      x: Math.random() * 2000,
      y: Math.random() * 2000,
      r: Math.random() * 1.8 + 0.3,
      a: Math.random(),
      twinkleSpeed: 0.005 + Math.random() * 0.02,
    });
  }

  // Floating asteroids
  interface Asteroid {
    x: number; y: number;
    vx: number; vy: number;
    size: number;
    rotation: number;
    rotSpeed: number;
    opacity: number;
    points: number[];
  }

  function makeAsteroid(): Asteroid {
    const size = 15 + Math.random() * 35;
    const numPoints = 6 + Math.floor(Math.random() * 4);
    const points: number[] = [];
    for (let i = 0; i < numPoints; i++) {
      points.push(0.6 + Math.random() * 0.4); // radius variation
    }
    return {
      x: Math.random() * 2000,
      y: Math.random() * 2000,
      vx: (Math.random() - 0.5) * 0.4,
      vy: (Math.random() - 0.5) * 0.4,
      size,
      rotation: Math.random() * Math.PI * 2,
      rotSpeed: (Math.random() - 0.5) * 0.01,
      opacity: 0.15 + Math.random() * 0.25,
      points,
    };
  }

  const asteroids: Asteroid[] = [];
  for (let i = 0; i < 12; i++) asteroids.push(makeAsteroid());

  function drawAsteroid(a: Asteroid) {
    ctx.save();
    ctx.translate(a.x, a.y);
    ctx.rotate(a.rotation);
    ctx.globalAlpha = a.opacity;
    ctx.beginPath();
    const n = a.points.length;
    for (let i = 0; i <= n; i++) {
      const angle = (i / n) * Math.PI * 2;
      const r = a.size * a.points[i % n];
      const px = Math.cos(angle) * r;
      const py = Math.sin(angle) * r;
      if (i === 0) ctx.moveTo(px, py);
      else ctx.lineTo(px, py);
    }
    ctx.closePath();
    ctx.strokeStyle = "rgba(255,255,255,0.3)";
    ctx.lineWidth = 1.5;
    ctx.stroke();
    ctx.fillStyle = "rgba(255,255,255,0.04)";
    ctx.fill();
    ctx.restore();
  }

  let spaceAnimId = 0;
  let spacePaused = false;

  document.addEventListener("visibilitychange", () => {
    spacePaused = document.hidden;
  });

  function loop() {
    spaceAnimId = requestAnimationFrame(loop);
    if (spacePaused) return;
    ctx.clearRect(0, 0, W, H);

    // Draw stars
    for (const s of stars) {
      s.a += s.twinkleSpeed;
      const alpha = 0.3 + Math.sin(s.a) * 0.4;
      ctx.beginPath();
      ctx.arc(s.x % W, s.y % H, s.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${Math.max(0, alpha)})`;
      ctx.fill();
    }

    // Update & draw asteroids
    for (const a of asteroids) {
      a.x += a.vx;
      a.y += a.vy;
      a.rotation += a.rotSpeed;

      // Wrap around
      if (a.x < -60) a.x = W + 50;
      if (a.x > W + 60) a.x = -50;
      if (a.y < -60) a.y = H + 50;
      if (a.y > H + 60) a.y = -50;

      drawAsteroid(a);
    }
  }

  loop();
</script>
