---
import "@fontsource/be-vietnam-pro";
import "@fontsource-variable/gabarito";
import { SITE_CONFIG } from "@config";
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";

const { lang } = SITE_CONFIG;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = stored === "light" || stored === "dark" ? stored : prefersDark ? "dark" : "light";
        root.classList.remove("light", "dark");
        root.classList.add(theme);
        root.style.colorScheme = theme;
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Asteroid Dodge | Shubham Pardule</title>
    <ViewTransitions />
    <style>
      *{margin:0;padding:0;box-sizing:border-box}
      body{overflow:hidden;touch-action:none;cursor:none}
      canvas{display:block;width:100vw;height:100vh}
      #start-screen,#game-over-screen,#pause-screen{
        position:fixed;inset:0;z-index:20;
        display:flex;flex-direction:column;
        align-items:center;justify-content:center;gap:12px;
        font-family:"Be Vietnam Pro",system-ui,sans-serif;
        cursor:default;
      }
      .dark #start-screen,.dark #game-over-screen,.dark #pause-screen{background:rgba(8,12,18,0.92)}
      .light #start-screen,.light #game-over-screen,.light #pause-screen{background:rgba(248,250,252,0.92)}
      .pause-title{font-size:2.4rem}
      .pause-stats{font-size:0.85rem;margin-top:2px}
      .dark .pause-stats{color:#64748b}
      .light .pause-stats{color:#94a3b8}
      .btn-quit{
        padding:10px 32px;border-radius:999px;
        font-size:0.85rem;font-weight:600;cursor:pointer;
        background:transparent;
        font-family:"Be Vietnam Pro",system-ui,sans-serif;
        transition:all 0.2s;
      }
      .dark .btn-quit{color:#94a3b8;border:1.5px solid rgba(255,255,255,0.12)}
      .light .btn-quit{color:#64748b;border:1.5px solid rgba(0,0,0,0.12)}
      .btn-quit:hover{background:rgba(239,68,68,0.15);border-color:#ef4444;color:#ef4444}
      .screen-title{font-family:"Gabarito Variable",ui-serif,serif;font-weight:800;letter-spacing:-1px}
      .start-title{font-size:3rem}
      .go-title{font-size:2.2rem}
      .dark .screen-title{color:#e2e8f0}
      .light .screen-title{color:#0f172a}
      .screen-sub{font-size:0.95rem;max-width:360px;text-align:center;line-height:1.6}
      .dark .screen-sub{color:#64748b}
      .light .screen-sub{color:#94a3b8}
      .screen-score{font-size:1.4rem;font-weight:700;font-family:"Gabarito Variable",ui-serif,serif}
      .dark .screen-score{color:#60a5fa}
      .light .screen-score{color:#2563eb}
      .screen-detail{font-size:0.8rem}
      .dark .screen-detail{color:#475569}
      .light .screen-detail{color:#94a3b8}
      .death-msg{font-size:0.95rem;font-style:italic;margin-top:4px}
      .dark .death-msg{color:#94a3b8}
      .light .death-msg{color:#475569}
      .btn-play{
        padding:16px 48px;border-radius:999px;border:2px solid transparent;
        font-size:1.05rem;font-weight:700;cursor:pointer;
        background:#2563eb;color:#fff;letter-spacing:0.5px;
        font-family:"Be Vietnam Pro",system-ui,sans-serif;
        transition:all 0.2s;margin-top:8px;
      }
      .btn-play:hover{background:#1d4ed8;transform:scale(1.05)}
      .btn-back{
        padding:8px 20px;border-radius:999px;
        font-size:0.8rem;font-weight:500;cursor:pointer;
        background:transparent;text-decoration:none;
        font-family:"Be Vietnam Pro",system-ui,sans-serif;
        transition:opacity 0.15s;
      }
      .dark .btn-back{color:#475569;border:1px solid rgba(255,255,255,0.08)}
      .light .btn-back{color:#94a3b8;border:1px solid rgba(0,0,0,0.1)}
      .btn-back:hover{opacity:0.6}
      .controls-hint{font-size:0.7rem;margin-top:4px;letter-spacing:0.3px;text-transform:uppercase}
      .dark .controls-hint{color:#334155}
      .light .controls-hint{color:#cbd5e1}
      #mute-btn{
        position:fixed;bottom:14px;left:14px;z-index:25;
        width:36px;height:36px;border-radius:50%;border:none;
        cursor:pointer;font-size:1.1rem;line-height:1;
        display:flex;align-items:center;justify-content:center;
        transition:opacity 0.15s;
      }
      .dark #mute-btn{background:rgba(255,255,255,0.08);color:#94a3b8}
      .light #mute-btn{background:rgba(0,0,0,0.06);color:#64748b}
      #mute-btn:hover{opacity:0.7}
      #tilt-btn{
        position:fixed;bottom:14px;left:58px;z-index:25;
        width:36px;height:36px;border-radius:50%;border:none;
        cursor:pointer;font-size:1.1rem;line-height:1;
        display:none;align-items:center;justify-content:center;
        transition:opacity 0.15s;
      }
      .dark #tilt-btn{background:rgba(255,255,255,0.08);color:#94a3b8}
      .light #tilt-btn{background:rgba(0,0,0,0.06);color:#64748b}
      #tilt-btn:hover{opacity:0.7}
      #tilt-btn.active{background:rgba(37,99,235,0.2);color:#60a5fa}
      #hud{
        position:fixed;top:14px;left:0;right:0;z-index:10;display:none;
        pointer-events:none;
        font-family:"Be Vietnam Pro",system-ui,sans-serif;
      }
      .hud-row{display:flex;align-items:center;justify-content:space-between;padding:0 20px}
      .hud-score{font-size:1.3rem;font-weight:700;font-family:"Gabarito Variable",serif}
      .dark .hud-score{color:#e2e8f0}
      .light .hud-score{color:#0f172a}
      .hud-lives{display:flex;gap:4px}
      .hud-heart{font-size:1rem;transition:transform 0.15s}
      .hud-combo{font-size:0.75rem;font-weight:600;opacity:0;transition:opacity 0.2s}
      .dark .hud-combo{color:#fbbf24}
      .light .hud-combo{color:#d97706}
      #wave-text{
        position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
        z-index:15;pointer-events:none;
        font-family:"Gabarito Variable",serif;font-weight:800;font-size:2rem;
        opacity:0;transition:opacity 0.4s;letter-spacing:-0.5px;
      }
      .dark #wave-text{color:rgba(226,232,240,0.6)}
      .light #wave-text{color:rgba(15,23,42,0.5)}
    </style>
  </head>
  <body class="bg-black">
    <canvas id="game"></canvas>
    <button id="mute-btn" title="Toggle sound">🔊</button>
    <button id="tilt-btn" title="Toggle tilt controls">📱</button>

    <div id="hud">
      <div class="hud-row">
        <div class="hud-score" id="hud-score">0</div>
        <div class="hud-combo" id="hud-combo"></div>
        <div class="hud-lives" id="hud-lives"></div>
      </div>
    </div>

    <div id="wave-text"></div>

    <div id="start-screen">
      <div class="screen-title start-title">ASTEROID DODGE</div>
      <div class="screen-sub">Tech logos are coming for you. Dodge, graze for bonus points, dash through danger, shoot to destroy, and try not to die.</div>
      <button class="btn-play" id="start-btn">START</button>
      <a href="/" class="btn-back" data-astro-reload>&larr; back to portfolio</a>
      <div class="controls-hint">mouse &middot; touch &middot; wasd &middot; arrows &middot; space to dash &middot; click/F to shoot</div>
    </div>

    <div id="game-over-screen" style="display:none;">
      <div class="screen-title go-title">WRECKED</div>
      <div class="death-msg" id="death-msg"></div>
      <div class="screen-score"><span id="go-score">0</span> pts</div>
      <div class="screen-detail">best: <span id="go-high">0</span> &middot; wave <span id="go-wave">1</span> &middot; <span id="go-near">0</span> near misses &middot; <span id="go-kills">0</span> kills &middot; best combo <span id="go-combo">0</span></div>
      <button class="btn-play" id="retry-btn">AGAIN</button>
      <a href="/" class="btn-back" data-astro-reload>&larr; back to portfolio</a>
    </div>

    <div id="pause-screen" style="display:none;">
      <div class="screen-title pause-title">PAUSED</div>
      <div class="pause-stats" id="pause-stats"></div>
      <button class="btn-play" id="resume-btn">RESUME</button>
      <button class="btn-quit" id="quit-btn">QUIT TO MENU</button>
      <div class="controls-hint">press ESC to resume</div>
    </div>

    <script>
      const cvs = document.getElementById("game") as HTMLCanvasElement;
      const ctx = cvs.getContext("2d")!;

      /* === Web Audio Sound Engine === */
      let audioCtx: AudioContext | null = null;
      let sfxMuted = localStorage.getItem("ad-mute") === "1";
      const elMuteBtn = document.getElementById("mute-btn")!;
      elMuteBtn.textContent = sfxMuted ? "\uD83D\uDD07" : "\uD83D\uDD0A";
      elMuteBtn.addEventListener("click", () => {
        sfxMuted = !sfxMuted;
        localStorage.setItem("ad-mute", sfxMuted ? "1" : "0");
        elMuteBtn.textContent = sfxMuted ? "\uD83D\uDD07" : "\uD83D\uDD0A";
      });
      function ensureAudio() {
        if (!audioCtx) audioCtx = new AudioContext();
        if (audioCtx.state === "suspended") audioCtx.resume();
      }
      function sfx(freq: number, dur: number, type: OscillatorType, vol: number, slide?: number) {
        if (sfxMuted || !audioCtx) return;
        const o = audioCtx.createOscillator();
        const g = audioCtx.createGain();
        o.type = type; o.frequency.value = freq;
        if (slide) o.frequency.linearRampToValueAtTime(slide, audioCtx.currentTime + dur);
        g.gain.value = Math.min(vol, 0.35);
        g.gain.linearRampToValueAtTime(0, audioCtx.currentTime + dur);
        o.connect(g); g.connect(audioCtx.destination);
        o.start(); o.stop(audioCtx.currentTime + dur);
      }
      function sfxNoise(dur: number, vol: number) {
        if (sfxMuted || !audioCtx) return;
        const buf = audioCtx.createBuffer(1, audioCtx.sampleRate * dur, audioCtx.sampleRate);
        const d = buf.getChannelData(0);
        for (let i = 0; i < d.length; i++) d[i] = (Math.random() * 2 - 1) * vol;
        const src = audioCtx.createBufferSource(); src.buffer = buf;
        const g = audioCtx.createGain(); g.gain.value = Math.min(vol, 0.3);
        g.gain.linearRampToValueAtTime(0, audioCtx.currentTime + dur);
        src.connect(g); g.connect(audioCtx.destination);
        src.start(); src.stop(audioCtx.currentTime + dur);
      }
      function sndGraze() { sfx(1200, 0.08, "sine", 0.15); sfx(1800, 0.06, "sine", 0.1); }
      function sndHit() { sfxNoise(0.2, 0.25); sfx(150, 0.25, "sawtooth", 0.2, 40); }
      function sndShoot() { sfx(800, 0.06, "square", 0.1, 400); }
      function sndDash() { sfx(300, 0.12, "sine", 0.12, 600); }
      function sndKill() { sfx(500, 0.1, "triangle", 0.12, 200); sfxNoise(0.08, 0.1); }
      function sndPowerUp() { sfx(400, 0.08, "sine", 0.12, 800); sfx(600, 0.12, "sine", 0.1, 1200); }
      function sndWave() { sfx(220, 0.3, "sawtooth", 0.12, 440); sfx(330, 0.25, "sawtooth", 0.08, 660); }
      function sndBossDefeat() { sfx(200, 0.5, "sawtooth", 0.18, 800); sfx(400, 0.4, "sine", 0.15, 1200); sfxNoise(0.3, 0.15); }
      function sndDeath() { sfx(400, 0.4, "sawtooth", 0.2, 80); sfxNoise(0.5, 0.2); sfx(200, 0.5, "square", 0.12, 50); }
      function sndBossHit() { sfx(300, 0.06, "square", 0.1, 150); }
      function sndStreak() { sfx(600, 0.1, "sine", 0.12, 1000); sfx(900, 0.12, "sine", 0.1, 1400); }

      /* === Haptics === */
      function vib(pattern: number | number[]) {
        try { if (navigator.vibrate) navigator.vibrate(pattern); } catch(_) {}
      }

      /* === Tilt Controls === */
      const elTiltBtn = document.getElementById("tilt-btn")!;
      let tiltEnabled = false;
      let tiltX = 0, tiltY = 0;
      let hasGyro = false;
      function onDeviceOrientation(ev: DeviceOrientationEvent) {
        if (!tiltEnabled || !on || paused) return;
        const g = ev.gamma || 0;
        const b = ev.beta || 0;
        tiltX = clamp(g / 30, -1, 1);
        tiltY = clamp((b - 40) / 30, -1, 1);
      }
      if (typeof DeviceOrientationEvent !== "undefined") {
        if ("ontouchstart" in window) {
          hasGyro = true;
          elTiltBtn.style.display = "flex";
        }
      }
      elTiltBtn.addEventListener("click", () => {
        tiltEnabled = !tiltEnabled;
        if (tiltEnabled) {
          elTiltBtn.classList.add("active");
          elTiltBtn.textContent = "\uD83C\uDFAE";
          if (typeof (DeviceOrientationEvent as any).requestPermission === "function") {
            (DeviceOrientationEvent as any).requestPermission().then((r: string) => {
              if (r === "granted") window.addEventListener("deviceorientation", onDeviceOrientation);
              else { tiltEnabled = false; elTiltBtn.classList.remove("active"); elTiltBtn.textContent = "\uD83D\uDCF1"; }
            });
          } else {
            window.addEventListener("deviceorientation", onDeviceOrientation);
          }
        } else {
          elTiltBtn.classList.remove("active");
          elTiltBtn.textContent = "\uD83D\uDCF1";
          window.removeEventListener("deviceorientation", onDeviceOrientation);
          tiltX = 0; tiltY = 0;
        }
      });

      const elHud      = document.getElementById("hud")!;
      const elScore    = document.getElementById("hud-score")!;
      const elCombo    = document.getElementById("hud-combo")!;
      const elLives    = document.getElementById("hud-lives")!;
      const elWave     = document.getElementById("wave-text")!;
      const elStart    = document.getElementById("start-screen")!;
      const elStartBtn = document.getElementById("start-btn")!;
      const elGo       = document.getElementById("game-over-screen")!;
      const elGoScore  = document.getElementById("go-score")!;
      const elGoHigh   = document.getElementById("go-high")!;
      const elGoWave   = document.getElementById("go-wave")!;
      const elGoNear   = document.getElementById("go-near")!;
      const elDeathMsg = document.getElementById("death-msg")!;
      const elRetryBtn = document.getElementById("retry-btn")!;
      const elGoKills  = document.getElementById("go-kills")!;
      const elGoCombo  = document.getElementById("go-combo")!;
      const elPause    = document.getElementById("pause-screen")!;
      const elPStats   = document.getElementById("pause-stats")!;
      const elResume   = document.getElementById("resume-btn")!;
      const elQuit     = document.getElementById("quit-btn")!;

      const QUIPS = [
        "skill issue tbh",
        "that Docker container got you good",
        "React rendered you out of existence",
        "you got npm uninstalled",
        "segfault: core dumped",
        "fatal: not a surviving repository",
        "your deployment failed",
        "404: pilot not found",
